<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>COL Games</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>

*{margin:0;padding:0;box-sizing:border-box;}

:root{
  --acid:#c8ff00;
  --cyan:#00f5ff;
  --dark:#070709;
  --surface:#0e0e14;
  --surface2:#14141e;
  --text:#e8e8f0;
  --muted:#6a6a80;
}

html{scroll-behavior:smooth;}

body{
  background:var(--dark);
  color:var(--text);
  font-family:'Rajdhani',sans-serif;
  font-size:18px;
  overflow-x:hidden;
  cursor:none;
}

.cursor{
  position:fixed;width:12px;height:12px;
  background:var(--acid);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  mix-blend-mode:difference;
}
.cursor-ring{
  position:fixed;width:38px;height:38px;
  border:1.5px solid var(--acid);border-radius:50%;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:width 0.25s,height 0.25s,border-color 0.2s;
  opacity:0.6;
}

body::before{
  content:'';
  position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity:0.03;pointer-events:none;z-index:1000;
}

/* HEADER */
header{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 60px;
  background:rgba(7,7,9,0.88);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(200,255,0,0.08);
}

.logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:26px;letter-spacing:4px;
  background:linear-gradient(90deg,var(--acid),var(--cyan));
  -webkit-background-clip:text;color:transparent;
  text-decoration:none;
}

.header-right{display:flex;align-items:center;gap:32px;}

nav{display:flex;gap:30px;align-items:center;}
nav a{
  color:var(--muted);text-decoration:none;
  font-size:12px;letter-spacing:3px;text-transform:uppercase;
  font-weight:600;transition:color 0.2s;position:relative;
}
nav a::after{
  content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;
  background:var(--acid);transition:width 0.3s;
}
nav a:hover{color:var(--acid);}
nav a:hover::after{width:100%;}

/* LANG SWITCHER */
.lang-switcher{position:relative;cursor:none;}

.lang-btn{
  display:flex;align-items:center;gap:8px;
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
  color:var(--text);padding:7px 14px;border-radius:2px;
  font-family:'Rajdhani',sans-serif;
  font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:600;
  cursor:none;transition:border-color 0.2s,background 0.2s;
}
.lang-btn:hover{border-color:var(--acid);background:rgba(200,255,0,0.06);}
.lang-btn svg{width:10px;height:10px;fill:none;stroke:currentColor;stroke-width:2.5;transition:transform 0.2s;}
.lang-switcher.open .lang-btn svg{transform:rotate(180deg);}
.lang-flag{font-size:15px;line-height:1;}

.lang-dropdown{
  position:absolute;top:calc(100% + 8px);right:0;
  background:#0e0e14;
  border:1px solid rgba(200,255,0,0.15);
  border-radius:2px;overflow:hidden;min-width:165px;
  opacity:0;visibility:hidden;
  transform:translateY(-6px);
  transition:opacity 0.2s,transform 0.2s,visibility 0.2s;
  z-index:600;
}
.lang-switcher.open .lang-dropdown{opacity:1;visibility:visible;transform:translateY(0);}

.lang-option{
  display:flex;align-items:center;gap:12px;
  padding:11px 16px;
  font-size:13px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;
  color:var(--muted);cursor:none;
  transition:background 0.15s,color 0.15s;
  border:none;background:none;width:100%;text-align:left;
  font-family:'Rajdhani',sans-serif;
}
.lang-option:hover{background:rgba(200,255,0,0.07);color:var(--acid);}
.lang-option.active{color:var(--acid);background:rgba(200,255,0,0.04);}

/* HERO */
.hero{
  min-height:100vh;
  display:flex;flex-direction:column;justify-content:center;
  padding:0 60px;position:relative;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 70% 60% at 80% 50%, rgba(200,255,0,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 50% 70% at 20% 80%, rgba(0,245,255,0.05) 0%, transparent 50%),
    var(--dark);
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(200,255,0,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,255,0,0.04) 1px, transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(ellipse at center, black 0%, transparent 70%);
}
.hero-content{position:relative;z-index:2;max-width:780px;}

.hero-eyebrow{
  font-size:12px;letter-spacing:5px;text-transform:uppercase;
  color:var(--acid);font-weight:700;margin-bottom:24px;
  display:flex;align-items:center;gap:14px;
  opacity:0;animation:fadeUp 0.8s 0.2s forwards;
}
.hero-eyebrow::before{content:'';width:40px;height:1px;background:var(--acid);}

.hero h1{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(68px,10vw,134px);
  line-height:0.92;letter-spacing:2px;margin-bottom:30px;
  opacity:0;animation:fadeUp 0.9s 0.4s forwards;
}
.hero h1 span{
  display:block;
  background:linear-gradient(90deg,var(--acid) 0%,var(--cyan) 60%,#ff4aff 100%);
  -webkit-background-clip:text;color:transparent;
}

.hero-sub{
  font-size:17px;color:var(--muted);line-height:1.7;
  max-width:480px;margin-bottom:50px;font-weight:300;letter-spacing:0.5px;
  opacity:0;animation:fadeUp 0.9s 0.6s forwards;
}
.hero-actions{
  display:flex;gap:20px;align-items:center;
  opacity:0;animation:fadeUp 0.9s 0.8s forwards;
}

.btn-primary{
  background:var(--acid);color:#000;
  padding:15px 38px;border-radius:2px;
  font-family:'Bebas Neue',sans-serif;
  font-size:18px;letter-spacing:3px;text-decoration:none;
  transition:background 0.2s,transform 0.15s,box-shadow 0.2s;display:inline-block;
}
.btn-primary:hover{
  background:var(--cyan);
  box-shadow:0 0 40px rgba(0,245,255,0.35);transform:translateY(-2px);
}
.btn-ghost{
  color:var(--text);padding:15px 38px;
  border:1px solid rgba(255,255,255,0.15);border-radius:2px;
  font-family:'Bebas Neue',sans-serif;
  font-size:18px;letter-spacing:3px;text-decoration:none;
  transition:border-color 0.2s,color 0.2s,transform 0.15s;display:inline-block;
}
.btn-ghost:hover{border-color:var(--acid);color:var(--acid);transform:translateY(-2px);}

.hero-stat-bar{
  position:absolute;right:60px;bottom:60px;z-index:2;
  display:flex;flex-direction:column;gap:28px;
  opacity:0;animation:fadeLeft 0.9s 1s forwards;
}
.stat{text-align:right;}
.stat-num{
  font-family:'Bebas Neue',sans-serif;font-size:46px;line-height:1;
  background:linear-gradient(90deg,var(--acid),var(--cyan));
  -webkit-background-clip:text;color:transparent;
}
.stat-label{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}

/* MARQUEE */
.marquee-bar{
  background:var(--acid);padding:13px 0;overflow:hidden;white-space:nowrap;
}
.marquee-inner{display:inline-block;animation:marquee 16s linear infinite;}
.marquee-inner span{
  font-family:'Bebas Neue',sans-serif;font-size:15px;
  letter-spacing:5px;color:#000;padding:0 40px;
}
.marquee-inner span.dot{color:rgba(0,0,0,0.3);}

/* GAME SECTION */
.section{padding:120px 60px;}
.section-header{
  display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:70px;
}
.section-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(42px,6vw,80px);letter-spacing:2px;line-height:1;
}
.section-title em{
  font-style:normal;
  background:linear-gradient(90deg,var(--acid),var(--cyan));
  -webkit-background-clip:text;color:transparent;
}
.section-tag{
  font-size:11px;letter-spacing:4px;text-transform:uppercase;
  color:var(--muted);border:1px solid rgba(255,255,255,0.1);
  padding:8px 18px;border-radius:2px;
}

.game-showcase{
  display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--surface);
}

.game-visual{
  background:linear-gradient(135deg,#080814,#0f0028);
  min-height:520px;position:relative;
  display:flex;align-items:center;justify-content:center;overflow:hidden;
}
.orb{position:absolute;border-radius:50%;}
.orb1{
  width:220px;height:220px;
  background:radial-gradient(circle,rgba(200,255,0,0.3),rgba(200,255,0,0.05),transparent 70%);
  animation:floatA 4s ease-in-out infinite;top:30%;left:28%;
}
.orb2{
  width:120px;height:120px;
  background:radial-gradient(circle,rgba(0,245,255,0.35),rgba(0,245,255,0.05),transparent 70%);
  animation:floatB 3.2s ease-in-out infinite;top:52%;left:56%;
}
.orb3{
  width:70px;height:70px;
  background:radial-gradient(circle,rgba(255,60,200,0.4),transparent 70%);
  animation:floatC 2.6s ease-in-out infinite;top:18%;left:60%;
}
.game-visual-label{
  position:absolute;bottom:28px;left:28px;
  font-size:10px;letter-spacing:4px;text-transform:uppercase;
  color:rgba(200,255,0,0.5);font-weight:700;
}

.game-info{
  padding:60px 56px;
  display:flex;flex-direction:column;justify-content:center;
}
.game-num{
  font-family:'Bebas Neue',sans-serif;font-size:100px;
  color:rgba(255,255,255,0.03);line-height:1;margin-bottom:10px;
}
.game-tag-el{
  font-size:10px;letter-spacing:4px;text-transform:uppercase;
  color:var(--acid);margin-bottom:18px;font-weight:700;
}
.game-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:64px;letter-spacing:2px;line-height:0.95;margin-bottom:22px;
}
.game-title span{color:var(--acid);}
.game-desc{
  color:var(--muted);line-height:1.8;margin-bottom:36px;font-weight:300;font-size:16px;
}
.game-features{display:flex;flex-direction:column;gap:12px;margin-bottom:40px;}
.game-feature{
  display:flex;align-items:center;gap:14px;
  font-size:14px;letter-spacing:1px;color:var(--text);font-weight:600;
}
.feature-dot{width:6px;height:6px;border-radius:50%;background:var(--acid);flex-shrink:0;}
.badge-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:40px;}
.badge{
  font-size:10px;letter-spacing:2px;text-transform:uppercase;
  border:1px solid rgba(200,255,0,0.25);color:var(--acid);
  padding:6px 14px;border-radius:2px;font-weight:600;
}

/* ABOUT */
.about{padding:0 60px 120px;}
.about-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.about-tag-el{
  font-size:11px;letter-spacing:5px;text-transform:uppercase;
  color:var(--cyan);margin-bottom:20px;display:block;font-weight:700;
}
.about-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(38px,5vw,66px);letter-spacing:2px;line-height:1;margin-bottom:24px;
}
.about-title em{
  font-style:normal;
  background:linear-gradient(90deg,var(--acid),var(--cyan));
  -webkit-background-clip:text;color:transparent;
}
.about-text{color:var(--muted);line-height:1.8;font-weight:300;margin-bottom:30px;}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;}
.stat-box{background:var(--surface);padding:36px 30px;}
.stat-box .num{
  font-family:'Bebas Neue',sans-serif;font-size:52px;
  background:linear-gradient(90deg,var(--acid),var(--cyan));
  -webkit-background-clip:text;color:transparent;line-height:1;
}
.stat-box .lbl{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-top:6px;font-weight:600;}

/* FOOTER */
footer{
  background:var(--surface);padding:60px;
  display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:40px;
  border-top:1px solid rgba(255,255,255,0.05);
}
.footer-logo{
  font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:5px;
  background:linear-gradient(90deg,var(--acid),var(--cyan));
  -webkit-background-clip:text;color:transparent;margin-bottom:16px;
}
.footer-copy{color:var(--muted);font-size:13px;line-height:1.8;font-weight:300;}
.footer-links h4{
  font-size:11px;letter-spacing:4px;text-transform:uppercase;
  color:var(--muted);margin-bottom:22px;
}
.footer-links a{
  display:block;color:var(--text);text-decoration:none;font-size:15px;
  margin-bottom:12px;transition:color 0.2s,padding-left 0.2s;
}
.footer-links a:hover{color:var(--acid);padding-left:8px;}
.footer-bottom{
  grid-column:1/-1;border-top:1px solid rgba(255,255,255,0.05);
  padding-top:28px;display:flex;justify-content:space-between;align-items:center;
}
.footer-bottom p{color:var(--muted);font-size:11px;letter-spacing:2px;}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
@keyframes fadeLeft{from{opacity:0;transform:translateX(30px);}to{opacity:1;transform:translateX(0);}}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}
@keyframes floatA{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(12px,-18px) scale(1.07);}}
@keyframes floatB{0%,100%{transform:translate(0,0);}50%{transform:translate(-14px,10px);}}
@keyframes floatC{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(10px,14px) scale(1.15);}}

.reveal{opacity:0;transform:translateY(40px);transition:opacity 0.7s ease,transform 0.7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-delay-1{transition-delay:0.12s;}
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<header>
  <a href="#" class="logo">COL Games</a>
  <div class="header-right">
    <nav>
      <a href="#" data-i18n="nav_home">Home</a>
      <a href="#games" data-i18n="nav_games">Games</a>
      <a href="#about" data-i18n="nav_about">About</a>
    </nav>
    <div class="lang-switcher" id="langSwitcher">
      <button class="lang-btn" id="langBtn" onclick="toggleLang()">
        <span class="lang-flag" id="currentFlag">🇬🇧</span>
        <span id="currentLangLabel">EN</span>
        <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="lang-dropdown" id="langDropdown">
        <button class="lang-option active" onclick="setLang('en')"><span>🇬🇧</span>&nbsp; English</button>
        <button class="lang-option" onclick="setLang('fr')"><span>🇫🇷</span>&nbsp; Français</button>
        <button class="lang-option" onclick="setLang('es')"><span>🇪🇸</span>&nbsp; Español</button>
        <button class="lang-option" onclick="setLang('ru')"><span>🇷🇺</span>&nbsp; Русский</button>
        <button class="lang-option" onclick="setLang('it')"><span>🇮🇹</span>&nbsp; Italiano</button>
        <button class="lang-option" onclick="setLang('ja')"><span>🇯🇵</span>&nbsp; 日本語</button>
      </div>
    </div>
  </div>
</header>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-content">
    <div class="hero-eyebrow" data-i18n="hero_eyebrow">First Title — Now Live</div>
    <h1>
      <span data-i18n="hero_h1_1">Catch.</span>
      <span data-i18n="hero_h1_2">Dodge.</span>
      <span data-i18n="hero_h1_3">Survive.</span>
    </h1>
    <p class="hero-sub" data-i18n="hero_sub">The first game from COL Games is here. A fast-paced arcade experience where reflexes are everything. How long can you last?</p>
    <div class="hero-actions">
      <a href="https://ollysss.github.io/first-game" target="_blank" class="btn-primary" data-i18n="hero_cta">Play Now — Free</a>
      <a href="#about" class="btn-ghost" data-i18n="hero_cta2">About Us</a>
    </div>
  </div>
  <div class="hero-stat-bar">
    <div class="stat">
      <div class="stat-num">Free</div>
      <div class="stat-label" data-i18n="stat1">To Play</div>
    </div>
    <div class="stat">
      <div class="stat-num">∞</div>
      <div class="stat-label" data-i18n="stat2">Replayability</div>
    </div>
    <div class="stat">
      <div class="stat-num">#1</div>
      <div class="stat-label" data-i18n="stat3">COL Release</div>
    </div>
  </div>
</section>

<div class="marquee-bar">
  <div class="marquee-inner">
    <span>CATCH &amp; DODGE</span><span class="dot">✦</span>
    <span>SPACE EDITION</span><span class="dot">✦</span>
    <span>FREE TO PLAY</span><span class="dot">✦</span>
    <span>COL GAMES</span><span class="dot">✦</span>
    <span>CATCH &amp; DODGE</span><span class="dot">✦</span>
    <span>SPACE EDITION</span><span class="dot">✦</span>
    <span>FREE TO PLAY</span><span class="dot">✦</span>
    <span>COL GAMES</span><span class="dot">✦</span>
    <span>CATCH &amp; DODGE</span><span class="dot">✦</span>
    <span>SPACE EDITION</span><span class="dot">✦</span>
    <span>FREE TO PLAY</span><span class="dot">✦</span>
    <span>COL GAMES</span><span class="dot">✦</span>
  </div>
</div>

<section class="section" id="games">
  <div class="section-header reveal">
    <h2 class="section-title" data-i18n="games_title">Our<br><em>Game</em></h2>
    <span class="section-tag" data-i18n="games_tag">1 Title Available</span>
  </div>
  <div class="game-showcase reveal reveal-delay-1">
    <div class="game-visual">
      <div class="orb orb1"></div>
      <div class="orb orb2"></div>
      <div class="orb orb3"></div>
      <div class="game-visual-label">CATCH &amp; DODGE — SPACE EDITION</div>
    </div>
    <div class="game-info">
      <div class="game-num">01</div>
      <div class="game-tag-el" data-i18n="game_tag">Arcade · Survival · Space</div>
      <h3 class="game-title">Catch &amp;<br><span>Dodge</span></h3>
      <p class="game-desc" data-i18n="game_desc">A high-intensity arcade game set in deep space. Collect gems, dodge enemies and obstacles, and push your high score to the limit. Simple to learn — impossible to master.</p>
      <div class="game-features">
        <div class="game-feature"><div class="feature-dot"></div><span data-i18n="feat1">Infinite levels with increasing difficulty</span></div>
        <div class="game-feature"><div class="feature-dot"></div><span data-i18n="feat2">Missions, skins &amp; permanent boosts</span></div>
        <div class="game-feature"><div class="feature-dot"></div><span data-i18n="feat3">Global leaderboard — beat your record</span></div>
        <div class="game-feature"><div class="feature-dot"></div><span data-i18n="feat4">Space Edition visual theme</span></div>
      </div>
      <div class="badge-row">
        <span class="badge" data-i18n="b1">Free to Play</span>
        <span class="badge" data-i18n="b2">Browser</span>
        <span class="badge" data-i18n="b3">Mobile Friendly</span>
      </div>
      <a href="https://ollysss.github.io/first-game" target="_blank" class="btn-primary" data-i18n="game_cta">Play Catch &amp; Dodge</a>
    </div>
  </div>
</section>

<section class="about" id="about">
  <div class="about-inner reveal">
    <div>
      <span class="about-tag-el" data-i18n="about_tag">Who We Are</span>
      <h2 class="about-title" data-i18n="about_title">Building<br><em>The Future</em><br>of Gaming.</h2>
      <p class="about-text" data-i18n="about_p1">COL Games is an independent studio with one goal: create games that are instantly fun and endlessly replayable. Catch &amp; Dodge is our first step.</p>
      <p class="about-text" data-i18n="about_p2">More titles are in development. Stay tuned — the best is yet to come.</p>
      <a href="https://ollysss.github.io/first-game" target="_blank" class="btn-primary" data-i18n="about_cta">Try the Game</a>
    </div>
    <div class="stats-grid">
      <div class="stat-box"><div class="num">1</div><div class="lbl" data-i18n="s1">Title Live</div></div>
      <div class="stat-box"><div class="num">∞</div><div class="lbl" data-i18n="s2">Runs Possible</div></div>
      <div class="stat-box"><div class="num">0€</div><div class="lbl" data-i18n="s3">Entry Cost</div></div>
      <div class="stat-box"><div class="num">100%</div><div class="lbl" data-i18n="s4">Browser Based</div></div>
    </div>
  </div>
</section>

<footer>
